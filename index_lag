<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>YT Quest — Task Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link
        href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=DM+Sans:wght@300;400;500;600&display=swap"
        rel="stylesheet">

    <style>
        /* ─────────────────────────────────────────────
   THEME VARIABLES
───────────────────────────────────────────── */
        :root {
            --bg-a: #020617;
            --bg-b: #0f172a;
            --card-bg: rgba(15, 23, 42, 0.75);
            --glass: rgba(30, 41, 59, 0.55);
            --glass2: rgba(51, 65, 85, 0.55);
            --border: rgba(255, 255, 255, 0.07);
            --accent: #22d3ee;
            --accent2: #6366f1;
            --accent3: #22c55e;
            --coin: #fbbf24;
            --text: #e2e8f0;
            --muted: #64748b;
            --danger: #f43f5e;
            --radius: 20px;
            --blur: blur(18px);
        }

        .theme-void {
            --bg-a: #020617;
            --bg-b: #0f172a;
            --accent: #22d3ee;
            --accent2: #6366f1;
            --accent3: #22c55e;
        }

        .theme-synthwave {
            --bg-a: #16001e;
            --bg-b: #2d0036;
            --accent: #f000ff;
            --accent2: #ff6ef7;
            --accent3: #ff4eb8;
        }

        .theme-ember {
            --bg-a: #0d0500;
            --bg-b: #1a0a00;
            --accent: #ff6a00;
            --accent2: #ee0979;
            --accent3: #ffb400;
        }

        .theme-aurora {
            --bg-a: #001a1a;
            --bg-b: #002233;
            --accent: #00ffc8;
            --accent2: #0099ff;
            --accent3: #7fff00;
        }

        .theme-gold {
            --bg-a: #0d0a00;
            --bg-b: #1a1400;
            --accent: #ffd700;
            --accent2: #ff8c00;
            --accent3: #ffec80;
        }

        /* ─────────────────────────────────────────────
   RESET & BASE
───────────────────────────────────────────── */
        *,
        *::before,
        *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: radial-gradient(ellipse at 20% 0%, rgba(99, 102, 241, .18) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 100%, rgba(34, 211, 238, .12) 0%, transparent 60%),
                linear-gradient(160deg, var(--bg-a) 0%, var(--bg-b) 100%);
            background-attachment: fixed;
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
            transition: background 0.6s ease;
        }

        /* noise overlay */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
            opacity: .4;
        }

        /* ─────────────────────────────────────────────
   HEADER
───────────────────────────────────────────── */
        .header {
            position: relative;
            z-index: 10;
            text-align: center;
            padding: 40px 20px 10px;
        }

        .header h1 {
            font-family: 'Orbitron', monospace;
            font-size: clamp(1.8rem, 5vw, 3.2rem);
            font-weight: 900;
            letter-spacing: 0.05em;
            background: linear-gradient(90deg, var(--accent), var(--accent2));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            filter: drop-shadow(0 0 20px color-mix(in srgb, var(--accent) 40%, transparent));
            animation: glowPulse 3s ease-in-out infinite alternate;
        }

        @keyframes glowPulse {
            from {
                filter: drop-shadow(0 0 12px color-mix(in srgb, var(--accent) 30%, transparent));
            }

            to {
                filter: drop-shadow(0 0 28px color-mix(in srgb, var(--accent) 60%, transparent));
            }
        }

        .header .subtitle {
            font-size: .9rem;
            color: var(--muted);
            margin-top: 6px;
            letter-spacing: .08em;
        }

        /* ─────────────────────────────────────────────
   HUD
───────────────────────────────────────────── */
        .hud {
            position: relative;
            z-index: 10;
            display: flex;
            justify-content: center;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
            margin: 28px auto;
            max-width: 700px;
            padding: 0 20px;
        }

        .hud-ring-wrap {
            position: relative;
            width: 110px;
            height: 110px;
            flex-shrink: 0;
        }

        .hud-ring-wrap svg {
            transform: rotate(-90deg);
        }

        .ring-bg {
            fill: none;
            stroke: rgba(255, 255, 255, .06);
            stroke-width: 9;
        }

        .ring-fill {
            fill: none;
            stroke: var(--accent);
            stroke-width: 9;
            stroke-linecap: round;
            stroke-dasharray: 314;
            stroke-dashoffset: 314;
            transition: stroke-dashoffset .6s cubic-bezier(.4, 0, .2, 1), stroke .4s;
            filter: drop-shadow(0 0 6px var(--accent));
        }

        .ring-label {
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-family: 'Orbitron', monospace;
            font-size: .7rem;
            color: var(--muted);
            gap: 2px;
        }

        .ring-level {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--accent);
        }

        .hud-stats {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .stat-pill {
            display: flex;
            align-items: center;
            gap: 10px;
            background: var(--glass);
            border: 1px solid var(--border);
            backdrop-filter: var(--blur);
            border-radius: 999px;
            padding: 8px 18px;
            font-size: .88rem;
            min-width: 180px;
        }

        .stat-pill .ico {
            font-size: 1.1rem;
        }

        .stat-pill .val {
            font-weight: 600;
            color: var(--accent);
            margin-left: auto;
            font-family: 'Orbitron', monospace;
            font-size: .8rem;
        }

        /* ─────────────────────────────────────────────
   TOOLBAR (search + theme)
───────────────────────────────────────────── */
        .toolbar {
            position: relative;
            z-index: 10;
            max-width: 900px;
            margin: 0 auto 28px;
            padding: 0 20px;
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            align-items: center;
            justify-content: center;
        }

        .search-wrap {
            flex: 1;
            min-width: 200px;
            max-width: 460px;
            position: relative;
        }

        .search-wrap input {
            width: 100%;
            padding: 13px 20px 13px 46px;
            border-radius: 999px;
            border: 1px solid var(--border);
            background: var(--glass);
            backdrop-filter: var(--blur);
            color: var(--text);
            font-size: .95rem;
            outline: none;
            transition: border-color .3s, box-shadow .3s;
        }

        .search-wrap input::placeholder {
            color: var(--muted);
        }

        .search-wrap input:focus {
            border-color: color-mix(in srgb, var(--accent) 50%, transparent);
            box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 12%, transparent);
        }

        .search-icon {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            font-size: 1rem;
            pointer-events: none;
        }

        .btn-shop {
            padding: 12px 22px;
            border-radius: 999px;
            border: 1px solid var(--border);
            background: var(--glass);
            backdrop-filter: var(--blur);
            color: var(--text);
            font-size: .9rem;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: background .2s, border-color .2s, transform .15s;
        }

        .btn-shop:hover {
            background: var(--glass2);
            border-color: color-mix(in srgb, var(--accent) 40%, transparent);
            transform: translateY(-1px);
        }

        /* ─────────────────────────────────────────────
   ACHIEVEMENTS BAR
───────────────────────────────────────────── */
        .achievements {
            position: relative;
            z-index: 10;
            display: flex;
            gap: 8px;
            justify-content: center;
            flex-wrap: wrap;
            max-width: 900px;
            margin: 0 auto 24px;
            padding: 0 20px;
        }

        .badge {
            background: var(--glass);
            border: 1px solid var(--border);
            border-radius: 999px;
            padding: 5px 14px;
            font-size: .78rem;
            display: flex;
            align-items: center;
            gap: 6px;
            backdrop-filter: var(--blur);
            opacity: .4;
            transition: opacity .3s, border-color .3s, box-shadow .3s;
        }

        .badge.earned {
            opacity: 1;
            border-color: color-mix(in srgb, var(--coin) 60%, transparent);
            box-shadow: 0 0 10px color-mix(in srgb, var(--coin) 25%, transparent);
        }

        /* ─────────────────────────────────────────────
   GRID
───────────────────────────────────────────── */
        .grid {
            position: relative;
            z-index: 5;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 24px;
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 20px 40px;
        }

        /* ─────────────────────────────────────────────
   CARD
───────────────────────────────────────────── */
        .card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
            backdrop-filter: var(--blur);
            box-shadow: 0 20px 60px rgba(0, 0, 0, .5);
            transition: transform .35s cubic-bezier(.34, 1.56, .64, 1), box-shadow .35s;
            animation: cardIn .5s ease both;
        }

        @keyframes cardIn {
            from {
                opacity: 0;
                transform: translateY(24px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .card:hover {
            transform: translateY(-10px) scale(1.015);
            box-shadow: 0 30px 80px rgba(0, 0, 0, .7),
                0 0 0 1px color-mix(in srgb, var(--accent) 20%, transparent);
        }

        /* thumbnail / embed */
        .thumb-wrap {
            position: relative;
            width: 100%;
            height: 200px;
            overflow: hidden;
            cursor: pointer;
        }

        .thumb-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform .5s;
        }

        .card:hover .thumb-wrap img {
            transform: scale(1.06);
        }

        .play-overlay {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(0, 0, 0, .35);
            transition: background .3s;
        }

        .card:hover .play-overlay {
            background: rgba(0, 0, 0, .2);
        }

        .play-btn {
            width: 54px;
            height: 54px;
            background: rgba(255, 255, 255, .9);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 24px rgba(0, 0, 0, .5);
            transition: transform .2s, box-shadow .2s;
        }

        .play-btn svg {
            width: 20px;
            fill: var(--bg-a);
            margin-left: 3px;
        }

        .thumb-wrap:hover .play-btn {
            transform: scale(1.1);
        }

        .card iframe {
            width: 100%;
            height: 210px;
            border: none;
            display: block;
        }

        /* card body */
        .card-body {
            padding: 18px;
        }

        .vid-label {
            display: flex;
            align-items: center;
            gap: 7px;
            margin-bottom: 14px;
        }

        .vid-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--accent);
            box-shadow: 0 0 8px var(--accent);
            flex-shrink: 0;
        }

        .vid-id {
            font-size: .78rem;
            color: var(--muted);
            font-family: 'Orbitron', monospace;
            letter-spacing: .04em;
        }

        /* tasks */
        .task {
            position: relative;
            background: var(--glass);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 13px 15px;
            margin-bottom: 9px;
            cursor: pointer;
            transition: background .2s, border-color .2s, transform .18s;
            overflow: hidden;
        }

        .task::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 3px;
            background: var(--accent);
            border-radius: 3px 0 0 3px;
            transition: background .3s;
        }

        .task:hover {
            background: var(--glass2);
            border-color: color-mix(in srgb, var(--accent) 30%, transparent);
            transform: translateX(4px);
        }

        .task.done {
            opacity: .42;
            cursor: default;
        }

        .task.done::before {
            background: var(--accent3);
        }

        .task.done .task-name {
            text-decoration: line-through;
            color: var(--muted);
        }

        .task-name {
            font-weight: 600;
            font-size: .9rem;
            margin-bottom: 4px;
            transition: color .2s;
        }

        .task:hover .task-name {
            color: var(--accent);
        }

        .task-meta {
            display: flex;
            gap: 8px;
            align-items: center;
            font-size: .75rem;
        }

        .priority-tag {
            padding: 2px 10px;
            border-radius: 999px;
            font-weight: 500;
        }

        .p-high {
            background: rgba(244, 63, 94, .15);
            color: #f43f5e;
        }

        .p-medium {
            background: rgba(251, 191, 36, .15);
            color: #fbbf24;
        }

        .p-low {
            background: rgba(34, 211, 238, .15);
            color: #22d3ee;
        }

        .task-desc {
            color: var(--muted);
            font-size: .78rem;
            margin-top: 5px;
            line-height: 1.5;
        }

        .done-checkmark {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--accent3);
            font-size: 1.1rem;
        }

        .watch-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            margin-top: 10px;
            color: var(--accent);
            font-size: .82rem;
            text-decoration: none;
            transition: gap .2s;
        }

        .watch-link:hover {
            gap: 10px;
            text-decoration: underline;
        }

        /* ─────────────────────────────────────────────
   SHOP MODAL
───────────────────────────────────────────── */
        .modal-overlay {
            position: fixed;
            inset: 0;
            z-index: 100;
            background: rgba(0, 0, 0, .75);
            backdrop-filter: blur(8px);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity .3s;
        }

        .modal-overlay.open {
            opacity: 1;
            pointer-events: all;
        }

        .modal {
            background: linear-gradient(145deg, rgba(15, 23, 42, .97), rgba(30, 41, 59, .97));
            border: 1px solid var(--border);
            border-radius: 28px;
            padding: 36px;
            width: min(560px, 94vw);
            max-height: 90vh;
            overflow-y: auto;
            box-shadow: 0 40px 100px rgba(0, 0, 0, .8);
            transform: translateY(20px);
            transition: transform .3s;
        }

        .modal-overlay.open .modal {
            transform: translateY(0);
        }

        .modal-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 28px;
        }

        .modal-title {
            font-family: 'Orbitron', monospace;
            font-size: 1.3rem;
            font-weight: 700;
            background: linear-gradient(90deg, var(--accent), var(--accent2));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .modal-close {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: var(--glass2);
            border: 1px solid var(--border);
            color: var(--text);
            font-size: 1.1rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background .2s;
        }

        .modal-close:hover {
            background: rgba(244, 63, 94, .2);
            color: #f43f5e;
        }

        .modal-coins-display {
            text-align: center;
            margin-bottom: 28px;
            font-family: 'Orbitron', monospace;
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--coin);
            text-shadow: 0 0 20px color-mix(in srgb, var(--coin) 40%, transparent);
        }

        /* shop sections */
        .shop-section {
            margin-bottom: 28px;
        }

        .shop-section-title {
            font-size: .8rem;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--muted);
            margin-bottom: 14px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .shop-section-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

        /* theme grid */
        .theme-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
            gap: 10px;
        }

        .theme-card {
            position: relative;
            border-radius: 14px;
            overflow: hidden;
            cursor: pointer;
            border: 2px solid transparent;
            transition: border-color .25s, transform .2s, box-shadow .2s;
            aspect-ratio: 1;
        }

        .theme-card:hover {
            transform: scale(1.05);
        }

        .theme-card.active {
            border-color: var(--accent);
            box-shadow: 0 0 16px color-mix(in srgb, var(--accent) 40%, transparent);
        }

        .theme-card .swatch {
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 4px;
            padding: 10px;
            font-size: .78rem;
            font-weight: 600;
            text-align: center;
        }

        .theme-card .cost {
            position: absolute;
            top: 6px;
            right: 6px;
            background: rgba(0, 0, 0, .6);
            border-radius: 999px;
            padding: 2px 7px;
            font-size: .68rem;
            color: var(--coin);
        }

        .theme-card .owned-badge {
            position: absolute;
            bottom: 6px;
            left: 6px;
            background: rgba(34, 197, 94, .2);
            color: #22c55e;
            border-radius: 999px;
            padding: 2px 7px;
            font-size: .68rem;
        }

        /* power-ups */
        .powerup-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .powerup-item {
            display: flex;
            align-items: center;
            gap: 14px;
            background: var(--glass);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 14px 16px;
            cursor: pointer;
            transition: background .2s, border-color .2s, transform .15s;
        }

        .powerup-item:hover {
            background: var(--glass2);
            border-color: color-mix(in srgb, var(--accent) 30%, transparent);
            transform: translateX(4px);
        }

        .powerup-icon {
            font-size: 1.5rem;
            flex-shrink: 0;
        }

        .powerup-info {
            flex: 1;
        }

        .powerup-name {
            font-weight: 600;
            font-size: .9rem;
            margin-bottom: 2px;
        }

        .powerup-desc {
            font-size: .75rem;
            color: var(--muted);
        }

        .powerup-cost {
            font-family: 'Orbitron', monospace;
            font-size: .8rem;
            color: var(--coin);
            font-weight: 700;
            white-space: nowrap;
        }

        /* ─────────────────────────────────────────────
   TOAST
───────────────────────────────────────────── */
        #toast-container {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 200;
            display: flex;
            flex-direction: column-reverse;
            gap: 10px;
            pointer-events: none;
        }

        .toast {
            background: linear-gradient(135deg, rgba(30, 41, 59, .97), rgba(15, 23, 42, .97));
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 14px 20px;
            font-size: .88rem;
            box-shadow: 0 12px 40px rgba(0, 0, 0, .6);
            animation: toastIn .35s cubic-bezier(.34, 1.56, .64, 1) both, toastOut .35s .3s ease forwards;
            display: flex;
            align-items: center;
            gap: 10px;
            min-width: 200px;
            pointer-events: none;
        }

        .toast.long {
            animation-delay: 0s;
            animation-duration: .35s, .35s;
            animation-delay: 0s, 2.5s;
        }

        @keyframes toastIn {
            from {
                opacity: 0;
                transform: translateX(30px)
            }

            to {
                opacity: 1;
                transform: none
            }
        }

        @keyframes toastOut {
            to {
                opacity: 0;
                transform: translateX(30px)
            }
        }

        /* ─────────────────────────────────────────────
   LEVEL-UP BANNER
───────────────────────────────────────────── */
        .levelup-banner {
            position: fixed;
            inset: 0;
            z-index: 300;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(0, 0, 0, .8);
            backdrop-filter: blur(12px);
            animation: fadeIn .3s ease both, fadeOut .5s 2s ease both;
            pointer-events: none;
        }

        @keyframes fadeIn {
            from {
                opacity: 0
            }

            to {
                opacity: 1
            }
        }

        @keyframes fadeOut {
            to {
                opacity: 0
            }
        }

        .levelup-inner {
            text-align: center;
            animation: popIn .5s cubic-bezier(.34, 1.56, .64, 1) both;
        }

        @keyframes popIn {
            from {
                transform: scale(.5)
            }

            to {
                transform: scale(1)
            }
        }

        .levelup-inner h2 {
            font-family: 'Orbitron', monospace;
            font-size: clamp(2rem, 8vw, 4rem);
            font-weight: 900;
            background: linear-gradient(90deg, var(--accent), var(--accent2));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            filter: drop-shadow(0 0 30px var(--accent));
            margin-bottom: 8px;
        }

        .levelup-inner p {
            font-size: 1.1rem;
            color: var(--muted);
        }

        .stars {
            font-size: 2.5rem;
            animation: spin 1s linear;
        }

        @keyframes spin {
            from {
                transform: rotate(-20deg)
            }

            to {
                transform: rotate(20deg)
            }
        }

        /* ─────────────────────────────────────────────
   EMPTY STATE
───────────────────────────────────────────── */
        .empty {
            text-align: center;
            padding: 60px 20px;
            color: var(--muted);
            grid-column: 1/-1;
        }

        .empty-icon {
            font-size: 3rem;
            margin-bottom: 12px;
        }

        .empty p {
            font-size: .95rem;
        }

        /* ─────────────────────────────────────────────
   SCROLLBAR
───────────────────────────────────────────── */
        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: var(--glass2);
            border-radius: 99px;
        }

        /* ─────────────────────────────────────────────
   RESPONSIVE
───────────────────────────────────────────── */
        @media(max-width:500px) {
            .hud {
                gap: 14px;
            }

            .hud-ring-wrap {
                width: 90px;
                height: 90px;
            }

            .grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body class="theme-void">

    <!-- ══════════════════════════ HEADER ══════════════════════════ -->
    <div class="header">
        <h1>⚡ YT Quest</h1>
        <p class="subtitle">Complete tasks · Earn coins · Level up</p>
    </div>

    <!-- ══════════════════════════ HUD ══════════════════════════ -->
    <div class="hud">
        <div class="hud-ring-wrap">
            <svg width="110" height="110">
                <circle class="ring-bg" cx="55" cy="55" r="46" />
                <circle class="ring-fill" id="ringFill" cx="55" cy="55" r="46" />
            </svg>
            <div class="ring-label">
                <span class="ring-level" id="ringLevel">1</span>
                <span>LEVEL</span>
            </div>
        </div>

        <div class="hud-stats">
            <div class="stat-pill">
                <span class="ico">🎯</span>
                <span>Progress</span>
                <span class="val" id="statProgress">0/1</span>
            </div>
            <div class="stat-pill">
                <span class="ico">💰</span>
                <span>Coins</span>
                <span class="val" id="statCoins">0</span>
            </div>
            <div class="stat-pill">
                <span class="ico">🔥</span>
                <span>Streak</span>
                <span class="val" id="statStreak">0</span>
            </div>
        </div>
    </div>

    <!-- ══════════════════════════ ACHIEVEMENTS ══════════════════════════ -->
    <div class="achievements" id="achievements"></div>

    <!-- ══════════════════════════ TOOLBAR ══════════════════════════ -->
    <div class="toolbar">
        <div class="search-wrap">
            <span class="search-icon">🔍</span>
            <input type="text" id="search" placeholder="Search tasks…" autocomplete="off" />
        </div>
        <button class="btn-shop" onclick="openShop()">🛒 Shop</button>
    </div>

    <!-- ══════════════════════════ GRID ══════════════════════════ -->
    <div class="grid" id="grid"></div>

    <!-- ══════════════════════════ SHOP MODAL ══════════════════════════ -->
    <div class="modal-overlay" id="shopModal">
        <div class="modal">
            <div class="modal-header">
                <span class="modal-title">🛒 Quest Shop</span>
                <button class="modal-close" onclick="closeShop()">✕</button>
            </div>

            <div class="modal-coins-display" id="shopCoins">💰 0</div>

            <!-- THEMES -->
            <div class="shop-section">
                <div class="shop-section-title">🎨 Themes</div>
                <div class="theme-grid" id="themeGrid"></div>
            </div>

            <!-- POWER-UPS -->
            <div class="shop-section">
                <div class="shop-section-title">⚡ Power-Ups</div>
                <div class="powerup-list" id="powerupList"></div>
            </div>
        </div>
    </div>

    <!-- ══════════════════════════ TOASTS ══════════════════════════ -->
    <div id="toast-container"></div>

    <!-- ══════════════════════════ JS ══════════════════════════ -->
    <script>
        /* ═══════════════════════════════════════════
           CONSTANTS
        ═══════════════════════════════════════════ */
        const THEMES = [
            { id: 'void', label: 'Void', emoji: '🌑', desc: 'Deep space dark', cost: 0, colors: ['#020617', '#22d3ee'] },
            { id: 'synthwave', label: 'Synthwave', emoji: '🌆', desc: 'Neon purple vibes', cost: 15, colors: ['#16001e', '#f000ff'] },
            { id: 'ember', label: 'Ember', emoji: '🔥', desc: 'Volcanic warmth', cost: 15, colors: ['#0d0500', '#ff6a00'] },
            { id: 'aurora', label: 'Aurora', emoji: '🌌', desc: 'Northern lights', cost: 15, colors: ['#001a1a', '#00ffc8'] },
            { id: 'gold', label: 'Royal Gold', emoji: '👑', desc: 'Luxury gold finish', cost: 25, colors: ['#0d0a00', '#ffd700'] },
        ];

        const POWERUPS = [
            { id: 'double_coins', label: 'Double Coins', emoji: '💎', desc: 'Next 5 tasks give 2× coins', cost: 20, duration: 5 },
            { id: 'xp_boost', label: 'XP Boost', emoji: '⚡', desc: 'Tasks count double for level', cost: 30, duration: 3 },
            { id: 'streak_shield', label: 'Streak Shield', emoji: '🛡️', desc: 'Protect your streak once', cost: 25, duration: 1 },
        ];

        const ACHIEVEMENTS_DEF = [
            { id: 'first', label: 'First Blood', emoji: '🗡️', req: g => Object.keys(g.doneTasks).length >= 1 },
            { id: 'ten', label: 'Task Hunter', emoji: '🏹', req: g => Object.keys(g.doneTasks).length >= 10 },
            { id: 'fifty', label: 'Grind Master', emoji: '💪', req: g => Object.keys(g.doneTasks).length >= 50 },
            { id: 'lv5', label: 'Level 5', emoji: '🌟', req: g => g.level >= 5 },
            { id: 'lv10', label: 'Level 10', emoji: '🏆', req: g => g.level >= 10 },
            { id: 'rich', label: 'Coin Hoarder', emoji: '💰', req: g => g.totalCoins >= 100 },
            { id: 'streak3', label: 'On Fire', emoji: '🔥', req: g => g.streak >= 3 },
        ];

        const LEVEL_STEPS = [1, 2, 3, 5, 7, 10];

        /* ═══════════════════════════════════════════
           GAME STATE
        ═══════════════════════════════════════════ */
        let game = JSON.parse(localStorage.getItem('ytq_game') || 'null') || {
            level: 1, completed: 0, coins: 0, totalCoins: 0,
            streak: 0, lastDate: null, doneTasks: {},
            achievements: [], ownedThemes: ['void'], activeTheme: 'void',
            activePowerup: null, powerupLeft: 0,
        };

        let allData = [];

        function getRequired(lvl) {
            return lvl <= LEVEL_STEPS.length ? LEVEL_STEPS[lvl - 1] : 10 + (lvl - LEVEL_STEPS.length) * 5;
        }

        function save() { localStorage.setItem('ytq_game', JSON.stringify(game)); }

        /* ═══════════════════════════════════════════
           TASK COMPLETION
        ═══════════════════════════════════════════ */
        function completeTask(id) {
            if (game.doneTasks[id]) return;

            game.doneTasks[id] = true;

            // coin reward
            let coins = 2;
            if (game.activePowerup === 'double_coins' && game.powerupLeft > 0) {
                coins = 4; game.powerupLeft--;
                if (game.powerupLeft <= 0) { game.activePowerup = null; toast('💎 Double Coins expired'); }
            }
            game.coins += coins;
            game.totalCoins += coins;
            toast(`+${coins} 💰 Coins earned!`);

            // xp
            let xpGain = 1;
            if (game.activePowerup === 'xp_boost' && game.powerupLeft > 0) {
                xpGain = 2; game.powerupLeft--;
                if (game.powerupLeft <= 0) { game.activePowerup = null; toast('⚡ XP Boost expired'); }
            }
            game.completed += xpGain;

            updateStreak();
            checkAchievements();

            if (game.completed >= getRequired(game.level)) {
                game.level++;
                game.completed = 0;
                game.coins += 10;
                game.totalCoins += 10;
                save();
                showLevelUp();
            }

            save();
            render(allData, document.getElementById('search').value);
            updateHUD();
        }

        /* ═══════════════════════════════════════════
           STREAK
        ═══════════════════════════════════════════ */
        function updateStreak() {
            const today = new Date().toDateString();
            if (game.lastDate === today) return;

            const yesterday = new Date();
            yesterday.setDate(yesterday.getDate() - 1);

            if (game.lastDate === yesterday.toDateString()) {
                game.streak++;
                toast(`🔥 Streak × ${game.streak}!`);
            } else {
                if (game.activePowerup === 'streak_shield') {
                    toast('🛡️ Streak Shield activated!'); game.activePowerup = null;
                } else {
                    game.streak = 1;
                }
            }
            game.lastDate = today;
        }

        /* ═══════════════════════════════════════════
           ACHIEVEMENTS
        ═══════════════════════════════════════════ */
        function checkAchievements() {
            ACHIEVEMENTS_DEF.forEach(a => {
                if (!game.achievements.includes(a.id) && a.req(game)) {
                    game.achievements.push(a.id);
                    game.coins += 5; game.totalCoins += 5;
                    toast(`🏆 Achievement: ${a.label} (+5 💰)`);
                }
            });
            renderAchievements();
        }

        function renderAchievements() {
            const el = document.getElementById('achievements');
            el.innerHTML = ACHIEVEMENTS_DEF.map(a => `
    <div class="badge ${game.achievements.includes(a.id) ? 'earned' : ''}">
      ${a.emoji} ${a.label}
    </div>
  `).join('');
        }

        /* ═══════════════════════════════════════════
           HUD UPDATE
        ═══════════════════════════════════════════ */
        function updateHUD() {
            const req = getRequired(game.level);
            const pct = Math.min(game.completed / req, 1);
            const circ = 2 * Math.PI * 46; // r=46

            document.getElementById('ringFill').style.strokeDashoffset = circ - pct * circ;
            document.getElementById('ringLevel').textContent = game.level;
            document.getElementById('statProgress').textContent = `${game.completed}/${req}`;
            document.getElementById('statCoins').textContent = game.coins;
            document.getElementById('statStreak').textContent = game.streak;

            // sync shop coins
            document.getElementById('shopCoins').textContent = `💰 ${game.coins} coins`;
        }

        /* ═══════════════════════════════════════════
           SHOP
        ═══════════════════════════════════════════ */
        function openShop() {
            renderShop();
            document.getElementById('shopModal').classList.add('open');
        }
        function closeShop() {
            document.getElementById('shopModal').classList.remove('open');
        }

        document.getElementById('shopModal').addEventListener('click', e => {
            if (e.target === e.currentTarget) closeShop();
        });

        function renderShop() {
            updateHUD();
            // themes
            const tg = document.getElementById('themeGrid');
            tg.innerHTML = THEMES.map(t => {
                const owned = game.ownedThemes.includes(t.id);
                const active = game.activeTheme === t.id;
                return `
      <div class="theme-card ${active ? 'active' : ''}"
           style="background:linear-gradient(135deg,${t.colors[0]},${t.colors[1]}20)"
           onclick="handleTheme('${t.id}',${t.cost})">
        <div class="swatch">
          <span style="font-size:1.6rem">${t.emoji}</span>
          <span>${t.label}</span>
        </div>
        ${!owned ? `<span class="cost">💰${t.cost}</span>` : ''}
        ${owned && active ? `<span class="owned-badge">✓ Active</span>` : ''}
        ${owned && !active ? `<span class="owned-badge">Owned</span>` : ''}
      </div>`;
            }).join('');

            // powerups
            const pl = document.getElementById('powerupList');
            pl.innerHTML = POWERUPS.map(p => {
                const isActive = game.activePowerup === p.id;
                return `
      <div class="powerup-item" onclick="buyPowerup('${p.id}',${p.cost},${p.duration})">
        <span class="powerup-icon">${p.emoji}</span>
        <div class="powerup-info">
          <div class="powerup-name">${p.label} ${isActive ? `<span style="color:var(--accent3);font-size:.75rem">(active ${game.powerupLeft} left)</span>` : ''}</div>
          <div class="powerup-desc">${p.desc}</div>
        </div>
        <span class="powerup-cost">💰${p.cost}</span>
      </div>`;
            }).join('');
        }

        function handleTheme(id, cost) {
            if (game.ownedThemes.includes(id)) {
                applyTheme(id);
            } else {
                if (game.coins < cost) { toast('❌ Not enough coins!'); return; }
                game.coins -= cost;
                game.ownedThemes.push(id);
                applyTheme(id);
                toast(`🎨 Theme unlocked: ${THEMES.find(t => t.id === id).label}`);
            }
            save(); updateHUD(); renderShop();
        }

        function applyTheme(id) {
            THEMES.forEach(t => document.body.classList.remove('theme-' + t.id));
            document.body.classList.add('theme-' + id);
            game.activeTheme = id;
        }

        function buyPowerup(id, cost, duration) {
            if (game.coins < cost) { toast('❌ Not enough coins!'); return; }
            if (game.activePowerup) { toast('❌ A power-up is already active!'); return; }
            game.coins -= cost;
            game.activePowerup = id;
            game.powerupLeft = duration;
            const pu = POWERUPS.find(p => p.id === id);
            toast(`${pu.emoji} ${pu.label} activated!`);
            save(); updateHUD(); renderShop();
        }

        /* ═══════════════════════════════════════════
           VIDEO
        ═══════════════════════════════════════════ */
        function playVideo(el, id) {
            el.outerHTML = `<iframe width="100%" height="210"
    src="https://www.youtube.com/embed/${id}?autoplay=1"
    allow="autoplay; encrypted-media" allowfullscreen></iframe>`;
        }

        /* ═══════════════════════════════════════════
           TOAST
        ═══════════════════════════════════════════ */
        function toast(msg) {
            const c = document.getElementById('toast-container');
            const t = document.createElement('div');
            t.className = 'toast long';
            t.textContent = msg;
            c.appendChild(t);
            setTimeout(() => t.remove(), 3200);
        }

        /* ═══════════════════════════════════════════
           LEVEL UP
        ═══════════════════════════════════════════ */
        function showLevelUp() {
            const el = document.createElement('div');
            el.className = 'levelup-banner';
            el.innerHTML = `
    <div class="levelup-inner">
      <div class="stars">✨ ⭐ ✨</div>
      <h2>LEVEL ${game.level}!</h2>
      <p>+10 bonus coins • Keep grinding</p>
    </div>`;
            document.body.appendChild(el);
            setTimeout(() => el.remove(), 2600);
        }

        /* ═══════════════════════════════════════════
           LOAD DATA
        ═══════════════════════════════════════════ */
        async function loadTasks() {
            try {
                const files = await fetch('files.json').then(r => r.json());
                const results = await Promise.all(
                    files.map(f => fetch(f).then(r => r.json()).then(d => ({ f, d })))
                );
                allData = results;
            } catch {
                // Demo fallback so the UI is visible without a server
                allData = [
                    {
                        f: 'demo1.json', d: {
                            video_id: 'dQw4w9WgXcQ', tasks: [
                                { task: 'Watch the full video', priority: 'High', description: 'Take notes as you go.' },
                                { task: 'Summarize key points', priority: 'Medium', description: 'Write a 3-line summary.' },
                                { task: 'Share with a friend', priority: 'Low', description: 'Spread the knowledge.' },
                            ]
                        }
                    },
                    {
                        f: 'demo2.json', d: {
                            video_id: '9bZkp7q19f0', tasks: [
                                { task: 'Analyze the rhythm', priority: 'High', description: 'Note time signature changes.' },
                                { task: 'Find the drop moment', priority: 'Medium', description: 'Timestamp it.' },
                            ]
                        }
                    },
                ];
            }
            render(allData, '');
            renderAchievements();
            updateHUD();
        }

        /* ═══════════════════════════════════════════
           RENDER
        ═══════════════════════════════════════════ */
        function render(data, query = '') {
            const grid = document.getElementById('grid');
            grid.innerHTML = '';
            let count = 0;

            data.forEach((item, ci) => {
                const vid = item.d.video_id;
                const tasks = item.d.tasks || [];
                const filtered = tasks.filter(t =>
                    !query || t.task.toLowerCase().includes(query.toLowerCase()) ||
                    (t.description || '').toLowerCase().includes(query.toLowerCase())
                );
                if (!filtered.length) return;
                count++;

                const card = document.createElement('div');
                card.className = 'card';
                card.style.animationDelay = (ci * 0.06) + 's';

                const tasksHTML = filtered.map((t, i) => {
                    const tid = `${vid}_${tasks.indexOf(t)}`;
                    const done = !!game.doneTasks[tid];
                    const pClass = t.priority?.toLowerCase() === 'high' ? 'p-high'
                        : t.priority?.toLowerCase() === 'low' ? 'p-low' : 'p-medium';
                    return `
        <div class="task ${done ? 'done' : ''}" onclick="${done ? '' : `completeTask('${tid}')`}">
          <div class="task-name">${t.task}</div>
          <div class="task-meta">
            <span class="priority-tag ${pClass}">${t.priority || 'Normal'}</span>
          </div>
          ${t.description ? `<div class="task-desc">${t.description}</div>` : ''}
          ${done ? `<span class="done-checkmark">✔</span>` : ''}
        </div>`;
                }).join('');

                card.innerHTML = `
      <div class="thumb-wrap" onclick="playVideo(this,'${vid}')">
        <img src="https://img.youtube.com/vi/${vid}/hqdefault.jpg" alt="thumbnail" loading="lazy"/>
        <div class="play-overlay">
          <div class="play-btn">
            <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
          </div>
        </div>
      </div>
      <div class="card-body">
        <div class="vid-label">
          <span class="vid-dot"></span>
          <span class="vid-id">${vid}</span>
        </div>
        ${tasksHTML}
        <a class="watch-link" href="https://www.youtube.com/watch?v=${vid}" target="_blank">
          Watch on YouTube →
        </a>
      </div>`;
                grid.appendChild(card);
            });

            if (!count) {
                grid.innerHTML = `<div class="empty">
      <div class="empty-icon">🔍</div>
      <p>No tasks match your search.</p>
    </div>`;
            }
        }

        /* ═══════════════════════════════════════════
           SEARCH
        ═══════════════════════════════════════════ */
        document.getElementById('search').addEventListener('input', e => {
            render(allData, e.target.value);
        });

        /* ═══════════════════════════════════════════
           INIT
        ═══════════════════════════════════════════ */
        applyTheme(game.activeTheme || 'void');
        loadTasks();
    </script>
</body>

</html>